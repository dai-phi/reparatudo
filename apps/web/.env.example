# API base URL (HTTP). Default in dev: http://localhost:3333
VITE_API_URL=http://localhost:3333

# WebSocket URL. Default: same host as API (ws:// or wss://)
# VITE_WS_URL=ws://localhost:3333

# Opcional: pré-preenche chave da tela admin KYC no frontend
# VITE_ADMIN_KYC_KEY=

# Opcional: validação simples do login admin frontend (sem link na UI pública)
# VITE_ADMIN_EMAIL=admin@empresa.com
# VITE_ADMIN_PASSWORD=troque-esta-senha
