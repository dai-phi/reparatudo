DATABASE_URL=postgresql://usuario:senha@host:5432/banco?sslmode=require
JWT_SECRET=uma-chave-segura
PORT=3333
HOST=0.0.0.0
# Mensalidade do prestador (BRL, valor real)
PROVIDER_MONTHLY_FEE=49.90

# E-mails transacionais (opcional). Sem SMTP válido, o envio é ignorado e regista-se um log.
# EMAIL_ENABLED=false força modo noop mesmo com credenciais.
EMAIL_ENABLED=
EMAIL_FROM="Repara Tudo <noreply@example.com>"
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# URL pública da app (ex.: link no e-mail quando o prestador aceita o pedido)
APP_PUBLIC_URL=http://localhost:5173
